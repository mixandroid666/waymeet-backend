# Copy to deploy/.env.prod on the server and fill in real values.
#   cp deploy/.env.prod.example deploy/.env.prod
# NEVER commit deploy/.env.prod — it holds secrets.
#
# Replace 1-2-3-4 with your server's public IPv4, using DASHES (sslip.io style):
#   server IP 203.0.113.45  ->  203-0-113-45
# If you own a domain, set API_DOMAIN/MEDIA_DOMAIN to real hostnames instead
# (e.g. api.waymeet.app) and point their DNS A records at the server.

# ---- TLS / public hostnames -------------------------------------------------
ACME_EMAIL=ittipon.kankaew@gmail.com
API_DOMAIN=api.1-2-3-4.sslip.io
MEDIA_DOMAIN=media.1-2-3-4.sslip.io

# ---- app --------------------------------------------------------------------
ENV=production
HTTP_ADDR=:8080

# ---- postgres + postgis -----------------------------------------------------
# These three feed the postgres container; DATABASE_URL must match them and use
# the compose service name "postgres" as host (not localhost).
POSTGRES_USER=waymeet
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password
POSTGRES_DB=waymeet
DATABASE_URL=postgres://waymeet:CHANGE_ME_strong_db_password@postgres:5432/waymeet?sslmode=disable

# ---- redis ------------------------------------------------------------------
REDIS_URL=redis://redis:6379/0

# ---- auth -------------------------------------------------------------------
# Generate: openssl rand -base64 48
JWT_SECRET=CHANGE_ME_long_random_secret
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=720h

# ---- object storage (MinIO) -------------------------------------------------
# S3_ENDPOINT is the PUBLIC https URL so presigned links work from clients.
# The api/worker reach MinIO through Caddy at this hostname.
S3_ENDPOINT=https://media.1-2-3-4.sslip.io
S3_REGION=us-east-1
S3_BUCKET=waymeet-media
S3_ACCESS_KEY=waymeet-minio
S3_SECRET_KEY=CHANGE_ME_strong_minio_password
# Host ONLY — do NOT append the bucket. The media store adds /<bucket> itself
# (mediastore/s3.go), so including it here doubles the path and breaks image URLs.
S3_MEDIA_BASE_URL=https://media.1-2-3-4.sslip.io

# ---- push (Firebase Cloud Messaging) ----------------------------------------
# Put the service-account JSON at deploy/secrets/fcm.json (mounted to /secrets).
FCM_CREDENTIALS_FILE=/secrets/fcm.json

# ---- email OTP (Resend) -----------------------------------------------------
# Leave RESEND_API_KEY empty to log OTP codes instead of emailing (dev default).
# OTP_EMAIL_FROM must be an address on a domain you've VERIFIED in Resend.
# The sandbox address onboarding@resend.dev only delivers to your own Resend
# account email; use a verified domain to reach any recipient.
# NOTE: this is an EXAMPLE file — put the real key only in deploy/.env.prod
# (gitignored), never here.
RESEND_API_KEY=re_your_resend_api_key_here
OTP_EMAIL_FROM=noreply@send.waymeet.app
