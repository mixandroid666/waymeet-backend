# Copy to .env and adjust. Loaded by docker-compose and read via os.Getenv.

# api
ENV=development
HTTP_ADDR=:8080

# postgres + postgis (matches docker-compose service)
DATABASE_URL=postgres://ruammit:ruammit@localhost:5432/ruammit?sslmode=disable

# redis (chat fan-out, cache, asynq queue)
REDIS_URL=redis://localhost:6379/0

# auth
JWT_SECRET=change-me-in-production
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=720h

# object storage (S3-compatible; MinIO in local dev)
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=ruammit-media
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin

# push (Firebase Cloud Messaging) — path to service-account json
FCM_CREDENTIALS_FILE=
